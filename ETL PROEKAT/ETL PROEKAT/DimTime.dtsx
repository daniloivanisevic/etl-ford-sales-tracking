          SQLTask:Connection="{D2D94E7D-EB72-4A62-B97F-F63C0CDD68D9}"
          SQLTask:SqlStatementSource="IF EXISTS &#xA;&#x9;(SELECT *&#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_FactSales_DimTime')&#xA;BEGIN&#xA;&#x9;ALTER TABLE [dbo].[FactSales] DROP CONSTRAINT [FK_FactSales_DimTime]&#xA;END&#xA;&#xA;IF EXISTS (&#xA;&#x9;SELECT * &#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_FactValuation_DimTime'&#xA;)&#xA;BEGIN&#xA;&#x9;ALTER TABLE [dbo].[FactValuation] DROP CONSTRAINT [FK_FactValuation_DimTime];&#xA;END&#xA;&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM sysobjects&#xA;&#x9;WHERE id = OBJECT_ID(N'DimTime'))&#xA;BEGIN&#xA;&#x9;DROP TABLE [dbo].[DimTime]&#xA;&#x9;CREATE TABLE [dbo].[DimTime](&#xA;&#x9;[DateSID] [int] NOT NULL,&#xA;&#x9;[Year] [int] NOT NULL,&#xA;&#x9;[Month] [varchar](50) NOT NULL,&#xA;&#x9;[Day] [int] NOT NULL,&#xA; CONSTRAINT [PK_DimTime] PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[DateSID] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
