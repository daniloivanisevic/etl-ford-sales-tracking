          SQLTask:SqlStatementSource="IF EXISTS &#xA;&#x9;(SELECT *&#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_FactSales_DimVehicle')&#xA;BEGIN&#xA;&#x9;ALTER TABLE [dbo].[FactSales] DROP CONSTRAINT [FK_FactSales_DimVehicle]&#xA;END&#xA;&#xA;IF EXISTS (&#xA;&#x9;SELECT * &#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_FactValuation_DimVehicle'&#xA;)&#xA;BEGIN&#xA;&#x9;ALTER TABLE [dbo].[FactValuation] DROP CONSTRAINT [FK_FactValuation_DimVehicle];&#xA;END&#xA;&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM sysobjects&#xA;&#x9;WHERE id = OBJECT_ID(N'DimVehicle'))&#xA;BEGIN&#xA;&#x9;DROP TABLE [dbo].[DimVehicle]&#xA;&#x9;CREATE TABLE [dbo].[DimVehicle](&#xA;&#x9;[VehicleSID] [int] IDENTITY(1,1) NOT NULL,&#xA;&#x9;[vin] [varchar](50) NOT NULL,&#xA;&#x9;[model] [varchar](75) NOT NULL,&#xA;&#x9;[year_of_production] [int] NOT NULL,&#xA;&#x9;[body] [varchar](75) NOT NULL,&#xA;&#x9;[transmission] [varchar](50) NULL,&#xA;&#x9;[color] [varchar](50) NULL,&#xA;&#x9;[interiror] [varchar](50) NULL,&#xA; CONSTRAINT [PK_DimVehicle] PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[VehicleSID] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
