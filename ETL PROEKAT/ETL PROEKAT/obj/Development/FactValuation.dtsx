          SQLTask:SqlStatementSource="&#xA;IF EXISTS&#xA; (SELECT *&#xA; FROM sysobjects&#xA; WHERE id = OBJECT_ID(N'FactValuation'))&#xA;BEGIN&#xA; DROP TABLE [dbo].[FactValuation]&#xA; CREATE TABLE [dbo].[FactValuation](&#xA; [ValuationSID] [int] IDENTITY(1,1) NOT NULL,&#xA; [VehicleSID] [int] NOT NULL,&#xA; [LocationSID] [int] NOT NULL,&#xA; [DateSID] [int] NOT NULL,&#xA; [condition] [varchar](50) NOT NULL,&#xA; [odometer] [int] NOT NULL,&#xA; [mmr] [money] NOT NULL,&#xA; [selling_price] [money] NOT NULL,&#xA; [value_gap] [money] NOT NULL,&#xA; CONSTRAINT [PK_FactValuation] PRIMARY KEY CLUSTERED &#xA;(&#xA; [ValuationSID] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;&#xA;ALTER TABLE [dbo].[FactValuation]  WITH CHECK ADD  CONSTRAINT [FK_FactValuation_DimLocation] FOREIGN KEY([LocationSID])&#xA;REFERENCES [dbo].[DimLocation] ([LocationSID])&#xA;&#xA;ALTER TABLE [dbo].[FactValuation] CHECK CONSTRAINT [FK_FactValuation_DimLocation]&#xA;&#xA;ALTER TABLE [dbo].[FactValuation]  WITH CHECK ADD  CONSTRAINT [FK_FactValuation_DimTime] FOREIGN KEY([DateSID])&#xA;REFERENCES [dbo].[DimTime] ([DateSID])&#xA;&#xA;ALTER TABLE [dbo].[FactValuation] CHECK CONSTRAINT [FK_FactValuation_DimTime]&#xA;&#xA;ALTER TABLE [dbo].[FactValuation]  WITH CHECK ADD  CONSTRAINT [FK_FactValuation_DimVehicle] FOREIGN KEY([VehicleSID])&#xA;REFERENCES [dbo].[DimVehicle] ([VehicleSID])&#xA;&#xA;ALTER TABLE [dbo].[FactValuation] CHECK CONSTRAINT [FK_FactValuation_DimVehicle]&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
