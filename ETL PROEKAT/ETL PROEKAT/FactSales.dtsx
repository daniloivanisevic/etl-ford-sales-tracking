          SQLTask:Connection="{D2D94E7D-EB72-4A62-B97F-F63C0CDD68D9}"
          SQLTask:SqlStatementSource="&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM sysobjects&#xA;&#x9;WHERE id = OBJECT_ID(N'FactSales'))&#xA;BEGIN&#xA;&#x9;DROP TABLE [dbo].[FactSales]&#xA;&#x9;CREATE TABLE [dbo].[FactSales](&#xA;&#x9;[SalesSID] [int] IDENTITY(1,1) NOT NULL,&#xA;&#x9;[DateSID] [int] NOT NULL,&#xA;&#x9;[VehicleSID] [int] NOT NULL,&#xA;&#x9;[CustomerSID] [int] NOT NULL,&#xA;&#x9;[SellerSID] [int] NOT NULL,&#xA;&#x9;[LocationSID] [int] NOT NULL,&#xA;&#x9;[selling_price] [money] NOT NULL,&#xA;&#x9;[Quantity] [int] NOT NULL,&#xA; CONSTRAINT [PK_FactSales] PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[SalesSID] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;&#xA;ALTER TABLE [dbo].[FactSales]  WITH CHECK ADD  CONSTRAINT [FK_FactSales_DimCustomer] FOREIGN KEY([CustomerSID])&#xA;REFERENCES [dbo].[DimCustomer] ([CustomerSID])&#xA;&#xA;ALTER TABLE [dbo].[FactSales] CHECK CONSTRAINT [FK_FactSales_DimCustomer]&#xA;&#xA;ALTER TABLE [dbo].[FactSales]  WITH CHECK ADD  CONSTRAINT [FK_FactSales_DimLocation] FOREIGN KEY([LocationSID])&#xA;REFERENCES [dbo].[DimLocation] ([LocationSID])&#xA;&#xA;ALTER TABLE [dbo].[FactSales] CHECK CONSTRAINT [FK_FactSales_DimLocation]&#xA;&#xA;ALTER TABLE [dbo].[FactSales]  WITH CHECK ADD  CONSTRAINT [FK_FactSales_DimSeller] FOREIGN KEY([SellerSID])&#xA;REFERENCES [dbo].[DimSeller] ([SellerSID])&#xA;&#xA;ALTER TABLE [dbo].[FactSales] CHECK CONSTRAINT [FK_FactSales_DimSeller]&#xA;&#xA;ALTER TABLE [dbo].[FactSales]  WITH CHECK ADD  CONSTRAINT [FK_FactSales_DimTime] FOREIGN KEY([DateSID])&#xA;REFERENCES [dbo].[DimTime] ([DateSID])&#xA;&#xA;ALTER TABLE [dbo].[FactSales] CHECK CONSTRAINT [FK_FactSales_DimTime]&#xA;&#xA;ALTER TABLE [dbo].[FactSales]  WITH CHECK ADD  CONSTRAINT [FK_FactSales_DimVehicle] FOREIGN KEY([VehicleSID])&#xA;REFERENCES [dbo].[DimVehicle] ([VehicleSID])&#xA;&#xA;ALTER TABLE [dbo].[FactSales] CHECK CONSTRAINT [FK_FactSales_DimVehicle]&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
